# Neon Postgres
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/quickfix?sslmode=require

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Meta Pixel — client-side (browser pixel init)
NEXT_PUBLIC_META_PIXEL_ID=PLACEHOLDER_PIXEL_ID

# Meta Conversions API — server-side only, never expose to client
# META_PIXEL_ID: same numeric ID as above (server copy, no NEXT_PUBLIC prefix)
# META_CAPI_TOKEN: System User access token from Meta Business Manager
#   → Business Settings → System Users → Generate Token → assign pixel permission
META_PIXEL_ID=PLACEHOLDER_PIXEL_ID
META_CAPI_TOKEN=your_capi_access_token_here

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production: https://www.quickfixwindshields.co

# Business contact (update with real details)
NEXT_PUBLIC_BUSINESS_PHONE=+91 98765 43210
NEXT_PUBLIC_BUSINESS_WHATSAPP=919876543210
